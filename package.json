{
  "name": "recruit-web",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "vue-tsc --noEmit",
    "test:scripts": "node --test scripts/swagger/__tests__/*.test.mjs",
    "generate:swagger:named": "node scripts/swagger/postprocess-swagger.mjs",
    "generate:client": "pnpm generate:swagger:named && openapi-ts"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7",
    "@tanstack/vue-query": "^5",
    "@vueuse/core": "^12",
    "ant-design-vue": "^4",
    "axios": "^1.13.4",
    "dayjs": "^1.11.20",
    "marked": "^18.0.2",
    "pinia": "^3",
    "vue": "^3.5",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96",
    "@tailwindcss/vite": "^4",
    "@vitejs/plugin-vue": "^5",
    "eslint": "^9",
    "eslint-plugin-vue": "^10",
    "tailwindcss": "^4",
    "typescript": "~5.7",
    "typescript-eslint": "^8",
    "unplugin-vue-components": "^0.28",
    "vite": "^6",
    "vue-tsc": "^2"
  }
}
